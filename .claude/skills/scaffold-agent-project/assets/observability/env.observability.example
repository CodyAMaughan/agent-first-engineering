# env.observability.example — OPT-IN telemetry for the local observability preset.
# Copy to `.env.observability` and source it (`set -a && . ./.env.observability`) BEFORE starting a
# workflow, then bring up the stack (assets/observability/docker-compose.yml). Nothing here is on
# by default — absent these vars, Claude Code exports no telemetry and the workflow is unchanged.
#
# All data goes to the LOCAL collector only (OTLP -> localhost). No usage leaves the host (FR-018).

# Turn on Claude Code's native OpenTelemetry export.
CLAUDE_CODE_ENABLE_TELEMETRY=1

# Enhanced telemetry beta: emit per-agent SPANS/traces (query_source main|subagent, agent.name,
# skill.name) so the live view attributes usage per agent/subagent/skill (FR-005, FR-015/016).
OTEL_LOG_USER_PROMPTS=0                     # keep prompt text off the wire (privacy)
CLAUDE_CODE_ENABLE_TELEMETRY_SPANS=1        # beta flag for spans (rename if the beta env changes)

# Point the OTLP exporter at the LOCAL collector from docker-compose.yml.
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_METRICS_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp

# Open the dashboards once the stack is up:
#   Phoenix (agent graph / traces):  http://localhost:6006
#   Grafana (OPTIONAL metrics, AGPL): http://localhost:3000   (only with --profile metrics)
