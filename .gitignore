# MkDocs build output
site/

# Python virtual environment
.venv/

# Python caches
__pycache__/
*.pyc

# Agent memory loop — transient buffers (the wiki .md files are committed)
.agent/memory/_staging.md
.agent/memory/session-log.md

# Budget guardrail — transient cost artifacts (cache + per-run ledger; the .gitkeep stays)
.agent/budget/price-table.cache.json
.agent/budget/runs/*.ndjson

# Claude Code plugin — GENERATED from canonical sources via `sh scripts/build-plugin.sh`
# (.agents/skills/ + .agent/hooks/ + .claude/agents/). The generator + marketplace.json stay tracked.
plugin/

# QA triage reports — generated per run by the qa-loop workflow (the .gitkeep stays)
qa/reports/
